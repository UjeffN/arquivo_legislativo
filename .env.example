# Copie este arquivo para .env e ajuste os valores do ambiente.

# Obrigatórias
SECRET_KEY=troque-esta-chave-por-uma-chave-secreta-longa-e-unica
ALLOWED_HOSTS=localhost,127.0.0.1

# Desenvolvimento local direto no runserver:
DEBUG=True
FORCE_SCRIPT_NAME=
CSRF_TRUSTED_ORIGINS=http://localhost:8000,http://127.0.0.1:8000
SECURE_SSL_REDIRECT=False
USE_X_FORWARDED_HOST=False

# Produção sob subcaminho /arquivo, atrás de proxy HTTPS:
# DEBUG=False
# FORCE_SCRIPT_NAME=/arquivo
# ALLOWED_HOSTS=sistemas.parauapebas.pa.leg.br
# CSRF_TRUSTED_ORIGINS=https://sistemas.parauapebas.pa.leg.br
# SECURE_SSL_REDIRECT=True
# USE_X_FORWARDED_HOST=True
# SECURE_HSTS_SECONDS=31536000
# SECURE_HSTS_INCLUDE_SUBDOMAINS=True
# SECURE_HSTS_PRELOAD=True
# SECURE_REFERRER_POLICY=same-origin
